rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedInAs(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function validProfile() {
      return request.resource.data.keys().hasOnly([
          'displayName',
          'email',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.keys().hasAll([
          'displayName',
          'email',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() > 0
        && request.resource.data.displayName.size() <= 60
        && request.resource.data.email is string
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp
        ;
    }

    function validExpense(userId, expenseId) {
      return request.resource.data.keys().hasOnly([
          'description',
          'amountCents',
          'category',
          'transactionType',
          'paymentMethod',
          'photoStoragePath',
          'photoFileName',
          'photoContentType',
          'occurredAt',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.keys().hasAll([
          'description',
          'amountCents',
          'category',
          'transactionType',
          'paymentMethod',
          'occurredAt',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.description is string
        && request.resource.data.description.size() > 0
        && request.resource.data.description.size() <= 120
        && request.resource.data.amountCents is int
        && request.resource.data.amountCents > 0
        && request.resource.data.amountCents <= 100000000000
        && request.resource.data.category is string
        && request.resource.data.category.size() > 0
        && request.resource.data.category.size() <= 50
        && request.resource.data.transactionType in ['expense', 'income']
        && (
          request.resource.data.paymentMethod == null
          || request.resource.data.paymentMethod in ['cash', 'card', 'bankTransfer']
        )
        && (
          !request.resource.data.keys().hasAny([
            'photoStoragePath',
            'photoFileName',
            'photoContentType'
          ])
          || (
            request.resource.data.keys().hasAll([
              'photoStoragePath',
              'photoFileName',
              'photoContentType'
            ])
            && request.resource.data.photoStoragePath
              == 'users/' + userId + '/expenses/' + expenseId + '/receipt'
            && request.resource.data.photoFileName is string
            && request.resource.data.photoFileName.size() > 0
            && request.resource.data.photoFileName.size() <= 120
            && request.resource.data.photoContentType in [
              'image/jpeg',
              'image/png',
              'image/webp'
            ]
          )
        )
        && request.resource.data.occurredAt is timestamp
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp;
    }

    function validSpendingLimits() {
      return request.resource.data.keys().hasOnly([
          'dailyLimitCents',
          'monthlyLimitCents',
          'excludeIncome',
          'updatedAt'
        ])
        && request.resource.data.keys().hasAll([
          'dailyLimitCents',
          'monthlyLimitCents',
          'excludeIncome',
          'updatedAt'
        ])
        && (
          request.resource.data.dailyLimitCents == null
          || (
            request.resource.data.dailyLimitCents is int
            && request.resource.data.dailyLimitCents > 0
            && request.resource.data.dailyLimitCents <= 100000000000
          )
        )
        && (
          request.resource.data.monthlyLimitCents == null
          || (
            request.resource.data.monthlyLimitCents is int
            && request.resource.data.monthlyLimitCents > 0
            && request.resource.data.monthlyLimitCents <= 100000000000
          )
        )
        && request.resource.data.excludeIncome is bool
        && request.resource.data.updatedAt is timestamp;
    }

    function validCustomCategories() {
      return request.resource.data.keys().hasOnly([
          'categories',
          'updatedAt'
        ])
        && request.resource.data.keys().hasAll([
          'categories',
          'updatedAt'
        ])
        && request.resource.data.categories is list
        && request.resource.data.updatedAt is timestamp;
    }

    function validRecurringExpense() {
      return request.resource.data.keys().hasOnly([
          'description',
          'amountCents',
          'category',
          'transactionType',
          'paymentMethod',
          'frequency',
          'startDate',
          'nextOccurrenceAt',
          'active',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.keys().hasAll([
          'description',
          'amountCents',
          'category',
          'transactionType',
          'paymentMethod',
          'frequency',
          'startDate',
          'nextOccurrenceAt',
          'active',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.description is string
        && request.resource.data.description.size() > 0
        && request.resource.data.description.size() <= 120
        && request.resource.data.amountCents is int
        && request.resource.data.amountCents > 0
        && request.resource.data.amountCents <= 100000000000
        && request.resource.data.category is string
        && request.resource.data.category.size() > 0
        && request.resource.data.category.size() <= 50
        && request.resource.data.transactionType in ['expense', 'income']
        && (
          request.resource.data.paymentMethod == null
          || request.resource.data.paymentMethod in ['cash', 'card', 'bankTransfer']
        )
        && request.resource.data.frequency in ['weekly', 'monthly']
        && request.resource.data.startDate is timestamp
        && request.resource.data.nextOccurrenceAt is timestamp
        && request.resource.data.active is bool
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp;
    }

    match /users/{userId} {
      allow read, delete: if signedInAs(userId);
      allow create: if signedInAs(userId) && validProfile();
      allow update: if signedInAs(userId)
        && validProfile()
        && request.resource.data.createdAt == resource.data.createdAt;

      match /expenses/{expenseId} {
        allow read, delete: if signedInAs(userId);
        allow create: if signedInAs(userId) && validExpense(userId, expenseId);
        allow update: if signedInAs(userId)
          && validExpense(userId, expenseId)
          && request.resource.data.createdAt == resource.data.createdAt;
      }

      match /recurring-expenses/{scheduleId} {
        allow read, delete: if signedInAs(userId);
        allow create: if signedInAs(userId) && validRecurringExpense();
        allow update: if signedInAs(userId)
          && validRecurringExpense()
          && request.resource.data.createdAt == resource.data.createdAt;
      }

      match /settings/spending-limits {
        allow read: if signedInAs(userId);
        allow create, update: if signedInAs(userId) && validSpendingLimits();
        allow delete: if signedInAs(userId);
      }

      match /settings/custom-categories {
        allow read: if signedInAs(userId);
        allow create, update: if signedInAs(userId) && validCustomCategories();
        allow delete: if signedInAs(userId);
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
