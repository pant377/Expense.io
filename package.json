{
  "name": "expense-io",
  "version": "1.0.0",
  "scripts": {
    "ng": "ng",
    "firebase:config": "node scripts/generate-firebase-config.mjs",
    "prestart": "npm run firebase:config",
    "start": "ng serve",
    "start:emulators": "ng serve --configuration emulator",
    "prebuild": "npm run firebase:config",
    "build": "ng build",
    "build:emulators": "ng build --configuration emulator",
    "android:assets": "npx --yes @capacitor/assets@3.0.5 generate --android --iconBackgroundColor #051832 --iconBackgroundColorDark #051832 --splashBackgroundColor #051832 --splashBackgroundColorDark #051832 --logoSplashScale 0.2",
    "android:sync": "npm run build && npx cap sync android",
    "android:open": "npx cap open android",
    "android:run": "node scripts/run-android.mjs",
    "prewatch": "npm run firebase:config",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --watch=false",
    "verify:production-build": "node scripts/verify-production-build.mjs",
    "firebase:emulators": "firebase emulators:start --project demo-expense-io",
    "firebase:deploy:hosting": "npm run build && npm run verify:production-build && firebase deploy --only hosting",
    "firebase:deploy": "npm run build && npm run verify:production-build && firebase deploy"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^20.3.25",
    "@angular/compiler": "^20.3.25",
    "@angular/core": "^20.3.25",
    "@angular/forms": "^20.3.25",
    "@angular/platform-browser": "^20.3.25",
    "@angular/router": "^20.3.25",
    "@capacitor-firebase/authentication": "^8.3.0",
    "@capacitor/android": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "firebase": "^12.14.0",
    "pdfjs-dist": "5.4.624",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular/build": "^20.3.28",
    "@angular/cli": "^20.3.28",
    "@angular/compiler-cli": "^20.3.25",
    "@capacitor/cli": "^8.4.1",
    "@types/jasmine": "~5.1.9",
    "firebase-tools": "^15.20.0",
    "jasmine-core": "~5.9.0",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.9.3"
  }
}
