{
  "name": "expense-io",
  "version": "1.0.0",
  "scripts": {
    "ng": "ng",
    "firebase:config": "node scripts/generate-firebase-config.mjs",
    "firebase:config:demo": "node scripts/generate-firebase-config.mjs --demo",
    "prestart": "npm run firebase:config",
    "start": "ng serve",
    "prestart:emulators": "npm run firebase:config:demo",
    "start:emulators": "ng serve --configuration emulator",
    "prebuild": "npm run firebase:config",
    "build": "ng build",
    "prebuild:emulators": "npm run firebase:config:demo",
    "build:emulators": "ng build --configuration emulator",
    "prewatch": "npm run firebase:config",
    "watch": "ng build --watch --configuration development",
    "pretest": "npm run firebase:config:demo",
    "test": "ng test --watch=false",
    "firebase:emulators": "firebase emulators:start --project demo-expense-io",
    "firebase:deploy": "npm run build && firebase deploy"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^20.3.25",
    "@angular/compiler": "^20.3.25",
    "@angular/core": "^20.3.25",
    "@angular/forms": "^20.3.25",
    "@angular/platform-browser": "^20.3.25",
    "@angular/router": "^20.3.25",
    "firebase": "^12.14.0",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular/build": "^20.3.28",
    "@angular/cli": "^20.3.28",
    "@angular/compiler-cli": "^20.3.25",
    "@types/jasmine": "~5.1.9",
    "firebase-tools": "^15.20.0",
    "jasmine-core": "~5.9.0",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.9.3"
  }
}
